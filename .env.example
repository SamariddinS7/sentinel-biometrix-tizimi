# ═══════════════════════════════════════════════════════════════════════════════
# Sentinel AI VMS — Environment Variables
#
# Copy to .env and fill in values before running.
# NEVER commit .env to source control.
# In production use Kubernetes Secrets or a secrets manager.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Application ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
LOG_LEVEL=debug

# ── Security (REQUIRED) ────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=

# Generate with: openssl rand -hex 32
SESSION_SECRET=

# 32-byte AES encryption key for credential storage
# Generate with: openssl rand -hex 32
VMS_ENCRYPTION_KEY=

# ── AI / Integrations (optional) ──────────────────────────────────────────────
# Google Gemini API key for AI-powered analysis
GEMINI_API_KEY=

# ── Database (optional — falls back to Firebase/Firestore) ────────────────────
# postgres://user:password@host:5432/dbname
POSTGRES_URL=
POSTGRES_REPLICA_URL=
POSTGRES_POOL_MAX=20
POSTGRES_SSL=false

# ── Cache (optional — falls back to in-process LRU) ───────────────────────────
# redis://[:password@]host:port
REDIS_URL=

# ── Message Bus (optional — falls back to in-process vmsEventService) ─────────
# nats://host:4222 or comma-separated: nats://host1:4222,nats://host2:4222
NATS_URL=
NATS_REPLICAS=1

# ── Object Storage (optional — falls back to local .data/storage/) ────────────
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_REGION=us-east-1
STORAGE_FORCE_PATH_STYLE=true

# ── Observability ──────────────────────────────────────────────────────────────
# Prometheus metrics port (default: app port /metrics endpoint)
METRICS_PORT=9090

# ── Bootstrap admin (first-run only, remove in production) ────────────────────
# BOOTSTRAP_ADMIN_PASSWORD=
