rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny all
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Users collection: Allow client-side CRUD
    match /users/{userId} {
      allow read, write: if true;
    }
    match /users/{userId}/{document=**} {
      allow read, write: if true;
    }
    
    // AttendanceLogs collection: Allow client-side logging
    match /attendanceLogs/{logId} {
      allow read, write: if true;
    }
    match /attendanceLogs/{logId}/{document=**} {
      allow read, write: if true;
    }
    
    // Cameras collection: Allow client-side camera management
    match /cameras/{cameraId} {
      allow read, write: if true;
    }
    match /cameras/{cameraId}/{document=**} {
      allow read, write: if true;
    }
  }
}
