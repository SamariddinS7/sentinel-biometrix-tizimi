{
  "uid": "sentinel-vms-overview",
  "title": "Sentinel VMS — Overview",
  "tags": ["sentinel", "vms", "overview"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "instance",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(up{job=\"sentinel-vms\"}, instance)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Instances Up",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": "Prometheus",
      "targets": [{ "expr": "sum(up{job=\"sentinel-vms\"})", "legendFormat": "Instances" }],
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "red", "value": 0 }, { "color": "yellow", "value": 1 }, { "color": "green", "value": 2 }] }, "mappings": [] } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Active Cameras",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": "Prometheus",
      "targets": [{ "expr": "sum(vms_cameras_active_total)", "legendFormat": "Cameras" }],
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": 0 }] } } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "AI Inference Latency (p99)",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": "Prometheus",
      "targets": [{ "expr": "histogram_quantile(0.99, rate(vms_ai_inference_duration_seconds_bucket[5m]))", "legendFormat": "p99" }],
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "s", "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 0.1 }, { "color": "red", "value": 0.5 }] } } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "HTTP Error Rate",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": "Prometheus",
      "targets": [{ "expr": "sum(rate(vms_http_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(vms_http_requests_total[5m]))", "legendFormat": "Error %" }],
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "percentunit", "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 0.01 }, { "color": "red", "value": 0.05 }] } } }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Open Alarms",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "datasource": "Prometheus",
      "targets": [{ "expr": "sum(vms_alarms_open_total)", "legendFormat": "Alarms" }],
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 20 }] } } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "HTTP Request Rate",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "sum(rate(vms_http_requests_total{status_code=~\"2..\"}[1m]))", "legendFormat": "2xx" },
        { "expr": "sum(rate(vms_http_requests_total{status_code=~\"4..\"}[1m]))", "legendFormat": "4xx" },
        { "expr": "sum(rate(vms_http_requests_total{status_code=~\"5..\"}[1m]))", "legendFormat": "5xx" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 10 } } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Response Latency Percentiles",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(vms_http_request_duration_seconds_bucket[5m]))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, rate(vms_http_request_duration_seconds_bucket[5m]))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, rate(vms_http_request_duration_seconds_bucket[5m]))", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "AI Inference Throughput",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "sum(rate(vms_ai_inference_total[1m]))", "legendFormat": "Inferences/s" },
        { "expr": "sum(rate(vms_ai_detections_total[1m]))", "legendFormat": "Detections/s" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "lineWidth": 2, "fillOpacity": 5 } } }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Active Tracks",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "sum(vms_active_tracks_total)", "legendFormat": "Active Tracks" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10 } } }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Memory Usage",
      "gridPos": { "x": 0, "y": 20, "w": 8, "h": 6 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "process_resident_memory_bytes{job=\"sentinel-vms\"}", "legendFormat": "RSS {{instance}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "CPU Usage",
      "gridPos": { "x": 8, "y": 20, "w": 8, "h": 6 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "rate(process_cpu_seconds_total{job=\"sentinel-vms\"}[1m])", "legendFormat": "CPU {{instance}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Event Loop Lag",
      "gridPos": { "x": 16, "y": 20, "w": 8, "h": 6 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "nodejs_eventloop_lag_seconds{job=\"sentinel-vms\"}", "legendFormat": "EL Lag {{instance}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 }, "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 0.1 }, { "color": "red", "value": 0.5 }] } } }
    }
  ]
}
